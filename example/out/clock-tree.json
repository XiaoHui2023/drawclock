{
  "clk_a": {
    "kind": "clock",
    "freq": 100000,
    "source": "inv0"
  },
  "clk_b": {
    "kind": "clock",
    "freq": 50000000,
    "source": "dto0"
  },
  "clk_mux": {
    "kind": "clock",
    "freq": 200000000,
    "source": "mux2"
  },
  "div0": {
    "kind": "div",
    "source": "xtal",
    "target": "dto0"
  },
  "dto0": {
    "kind": "dto",
    "source": "div0",
    "target": "clk_b"
  },
  "gate0": {
    "kind": "gate",
    "source": "xtal",
    "target": "inv0"
  },
  "inv0": {
    "kind": "inv",
    "source": "gate0",
    "target": "clk_a"
  },
  "mux2": {
    "kind": "mux",
    "source": {
      "0": "pll_m2a",
      "1": "pll_m2b"
    },
    "target": "clk_mux"
  },
  "pll_m2a": {
    "kind": "pll",
    "targets": [
      "mux2"
    ]
  },
  "pll_m2b": {
    "kind": "pll",
    "targets": [
      "mux2"
    ]
  },
  "pll_main": {
    "kind": "pll",
    "targets": [
      "gate0",
      "div0"
    ]
  },
  "xtal": {
    "kind": "source",
    "targets": [
      "gate0",
      "div0"
    ]
  }
}
